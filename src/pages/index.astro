---
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);

const interests = [
  'Quadruped locomotion',
  'Reinforcement learning',
  'Sim2Real',
  'Robot dynamics',
  'MPPI',
  'World models',
  'VLA',
  'Embodied AI'
];

const profile = [
  ['Education', 'Applied Physics undergraduate, Southwest Jiaotong University'],
  ['Research', 'Robotics control, reinforcement learning, dynamics modeling, embodied intelligence'],
  ['Academic note', 'Top-ranked undergraduate with national scholarship experience'],
  ['Contact', 'hyl00250083@outlook.com']
];

const stack = [
  ['Robotics', 'ROS2, real robot deployment, multi-motor control, real-time debugging'],
  ['RL / Simulation', 'Isaac Lab, Isaac Sim, PPO, RSL-RL, PyTorch, domain randomization'],
  ['Control / Modeling', 'MPPI, nonlinear dynamics, Brush Model, MATLAB, Simulink, Simscape Multibody'],
  ['Embedded', 'STM32H7, RK3588, C/C++, Linux robot systems'],
  ['Development', 'Python, C++, Git, Docker, Distrobox, Arch Linux, Ubuntu']
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Hao Yunlai's CV-style research homepage for robotics control, reinforcement learning, Sim2Real, and embodied AI."
    />
    <title>Hao Yunlai | Robotics Control & Embodied AI</title>
  </head>
  <body>
    <main class="page-shell">
      <header class="masthead" aria-labelledby="page-title">
        <div>
          <p class="label">Personal Research Homepage</p>
          <h1 id="page-title">Hao Yunlai</h1>
          <p class="subtitle">
            Applied Physics undergraduate at SWJTU. I work on robotics control,
            reinforcement learning, Sim2Real, dynamics modeling, and embodied intelligence.
          </p>
          <p class="subtitle zh">
            从真实机器人控制问题出发，关注四足运动控制、Sim2Real、MPPI、World Model 与 VLA。
          </p>
        </div>
        <address class="contact-line" aria-label="Contact links">
          <a href="mailto:hyl00250083@outlook.com">Email</a>
          <a href="https://github.com/h4cii">GitHub</a>
          <span>SWJTU / Applied Physics</span>
        </address>
      </header>

      <nav class="quick-links" aria-label="Page sections">
        <a href="#profile">Profile</a>
        <a href="#projects">Projects</a>
        <a href="#demos">Debug Videos</a>
        <a href="#cv">CV Snapshot</a>
      </nav>

      <div class="content-grid">
        <article class="main-column">
          <section class="section" id="profile" aria-labelledby="profile-title">
            <p class="label">Research Profile</p>
            <h2 id="profile-title">Control-oriented robotics and embodied intelligence</h2>
            <div class="essay">
              <p>
                My work starts from deployable robot control: building dynamics-aware
                policies in simulation, testing them under model mismatch, and moving
                useful behavior onto physical robots.
              </p>
              <p>
                I am especially interested in the meeting point of model-based control,
                reinforcement learning, world models, and vision-language-action systems.
                The practical question behind the work is simple: how can a policy become
                reliable enough to matter on hardware?
              </p>
              <p>
                我希望把控制理论、强化学习和具身智能连接到真实机器人系统中，让算法不仅在仿真里表现好，
                也能在硬件约束、噪声、延迟和模型误差下稳定工作。
              </p>
            </div>
            <div class="interest-list" aria-label="Research interests">
              {interests.map((item) => <span>{item}</span>)}
            </div>
          </section>

          <section class="section" id="projects" aria-labelledby="projects-title">
            <p class="label">Selected Projects</p>
            <h2 id="projects-title">Project experience</h2>

            <div class="project-list">
              {
                projects.map((project) => (
                  <article class="project-entry">
                    <div class="project-meta">
                      <span>{project.data.status}</span>
                      <div class="tag-list" aria-label={`${project.data.title} focus areas`}>
                        {project.data.focus.map((item) => <em>{item}</em>)}
                      </div>
                    </div>

                    <div class="project-body">
                      <h3>{project.data.title}</h3>
                      <p>{project.data.subtitle}</p>
                      <ul>
                        {project.data.methods.map((method) => <li>{method}</li>)}
                      </ul>
                    </div>
                  </article>
                ))
              }
            </div>
          </section>

          <section class="section" id="demos" aria-labelledby="demos-title">
            <p class="label">Debug Videos</p>
            <h2 id="demos-title">Short demo evidence</h2>
            <p class="section-note">
              This area is reserved for sanitized short clips. Full raw debugging videos should
              stay external unless they are already public-safe.
            </p>

            <div class="demo-list">
              {
                projects.map((project) => (
                  <article class="demo-entry">
                    <div class="demo-media">
                      {project.data.previewSrc ? (
                        <video
                          controls
                          muted
                          playsinline
                          preload="metadata"
                          aria-label={`${project.data.title} preview video`}
                        >
                          <source src={project.data.previewSrc} />
                          <a href={project.data.previewSrc}>Open preview video</a>
                        </video>
                      ) : (
                        <div class="demo-placeholder">
                          <span>Preview pending</span>
                          <small>{project.data.previewLabel}</small>
                        </div>
                      )}
                    </div>
                    <div class="demo-copy">
                      <h3>{project.data.title}</h3>
                      <p>{project.data.privacyNote}</p>
                      {project.data.fullDemoUrl ? (
                        <a class="text-link" href={project.data.fullDemoUrl}>Watch full demo</a>
                      ) : (
                        <span class="muted-link">Full demo link pending</span>
                      )}
                    </div>
                  </article>
                ))
              }
            </div>
          </section>
        </article>

        <aside class="side-column" aria-label="CV snapshot">
          <section class="aside-block" id="cv">
            <p class="label">CV Snapshot</p>
            <dl class="profile-list">
              {
                profile.map(([label, value]) => (
                  <>
                    <dt>{label}</dt>
                    <dd>{value}</dd>
                  </>
                ))
              }
            </dl>
          </section>

          <section class="aside-block">
            <p class="label">Technical Stack</p>
            <div class="stack-list">
              {
                stack.map(([label, value]) => (
                  <div class="stack-item">
                    <strong>{label}</strong>
                    <span>{value}</span>
                  </div>
                ))
              }
            </div>
          </section>
        </aside>
      </div>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --bg: #f6f7f9;
    --paper: #ffffff;
    --ink: #182235;
    --muted: #667085;
    --soft: #f0f3f7;
    --line: #d9e0ea;
    --blue: #2558a7;
    --green: #19715f;
    --red: #a7444f;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--ink);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    line-height: 1.62;
  }

  a {
    color: var(--blue);
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
  }

  .page-shell {
    width: calc(100% - 36px);
    max-width: 1080px;
    margin: 0 auto;
    padding: 40px 0 72px;
  }

  .masthead {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 32px;
    align-items: end;
    border-bottom: 2px solid var(--ink);
    padding-bottom: 28px;
  }

  .label {
    margin: 0 0 10px;
    color: var(--blue);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p,
  dd,
  a,
  span,
  small,
  em {
    max-width: 100%;
    overflow-wrap: anywhere;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    margin-bottom: 14px;
    font-size: clamp(2.6rem, 6vw, 4.8rem);
    line-height: 0.98;
    letter-spacing: 0;
  }

  h2 {
    margin-bottom: 18px;
    font-size: clamp(1.45rem, 2.4vw, 2rem);
    line-height: 1.18;
    letter-spacing: 0;
  }

  h3 {
    margin-bottom: 8px;
    font-size: 1.08rem;
    line-height: 1.25;
    letter-spacing: 0;
  }

  .subtitle {
    max-width: 760px;
    margin-bottom: 8px;
    color: #29364d;
    font-size: 1.08rem;
  }

  .subtitle.zh {
    color: var(--muted);
    font-size: 1rem;
  }

  .contact-line {
    display: grid;
    gap: 6px;
    min-width: 210px;
    margin: 0;
    color: var(--muted);
    font-style: normal;
    text-align: right;
  }

  .contact-line span {
    color: #39465b;
  }

  .quick-links {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    border-bottom: 1px solid var(--line);
    padding: 14px 0;
    font-size: 0.94rem;
  }

  .quick-links a {
    color: #344054;
    font-weight: 700;
    text-decoration: none;
  }

  .content-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 310px;
    gap: 42px;
    align-items: start;
  }

  .section {
    padding: 42px 0;
    border-bottom: 1px solid var(--line);
  }

  .essay {
    display: grid;
    gap: 12px;
    color: #344054;
  }

  .essay p {
    margin-bottom: 0;
  }

  .interest-list,
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 22px;
  }

  .interest-list span,
  .tag-list em {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 5px 10px;
    background: var(--paper);
    color: #344054;
    font-size: 0.88rem;
    font-style: normal;
    font-weight: 650;
  }

  .project-list,
  .demo-list,
  .stack-list {
    display: grid;
    gap: 18px;
  }

  .project-entry {
    display: grid;
    grid-template-columns: 210px minmax(0, 1fr);
    gap: 24px;
    padding: 22px 0;
    border-top: 1px solid var(--line);
  }

  .project-entry:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .project-meta > span {
    display: block;
    color: var(--red);
    font-size: 0.86rem;
    font-weight: 750;
  }

  .project-body p,
  .section-note,
  .demo-copy p {
    color: #48566d;
  }

  ul {
    margin: 12px 0 0;
    padding-left: 18px;
    color: #344054;
  }

  li + li {
    margin-top: 5px;
  }

  .demo-entry {
    display: grid;
    grid-template-columns: 260px minmax(0, 1fr);
    gap: 20px;
    align-items: stretch;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--paper);
    padding: 14px;
  }

  .demo-media {
    min-height: 150px;
    border: 1px solid var(--line);
    border-radius: 6px;
    overflow: hidden;
    background: var(--soft);
  }

  video {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 150px;
    object-fit: cover;
  }

  .demo-placeholder {
    display: grid;
    align-content: center;
    min-height: 150px;
    padding: 16px;
    color: #344054;
  }

  .demo-placeholder span {
    font-weight: 800;
  }

  .demo-placeholder small {
    color: var(--muted);
  }

  .demo-copy {
    display: grid;
    align-content: center;
  }

  .text-link,
  .muted-link {
    font-size: 0.94rem;
    font-weight: 700;
  }

  .muted-link {
    color: var(--muted);
  }

  .side-column {
    position: sticky;
    top: 24px;
    padding-top: 42px;
  }

  .aside-block {
    border-top: 2px solid var(--ink);
    padding: 18px 0 28px;
  }

  .profile-list {
    display: grid;
    gap: 10px;
    margin: 0;
  }

  .profile-list dt {
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .profile-list dd {
    margin: 0 0 10px;
    color: #29364d;
  }

  .stack-item {
    display: grid;
    gap: 3px;
    border-left: 3px solid var(--green);
    padding-left: 12px;
  }

  .stack-item strong {
    color: #243047;
  }

  .stack-item span {
    color: var(--muted);
    font-size: 0.94rem;
  }

  @media (max-width: 900px) {
    .page-shell {
      width: calc(100% - 24px);
      padding-top: 28px;
    }

    .masthead,
    .content-grid,
    .project-entry,
    .demo-entry {
      grid-template-columns: 1fr;
    }

    .contact-line {
      min-width: 0;
      text-align: left;
    }

    .side-column {
      position: static;
      padding-top: 0;
    }
  }

  @media (max-width: 560px) {
    h1 {
      font-size: 2.8rem;
    }

    .quick-links {
      gap: 12px;
    }

    .section {
      padding: 34px 0;
    }

    .demo-entry {
      padding: 12px;
    }
  }
</style>
