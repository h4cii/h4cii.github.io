---
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);

const interests = [
  'Quadruped locomotion',
  'Reinforcement learning',
  'Sim2Real',
  'Robot dynamics',
  'MPPI',
  'World models',
  'VLA',
  'Embodied AI'
];

const profile = [
  ['Education', 'Applied Physics undergraduate, Southwest Jiaotong University'],
  ['Research', 'Robotics control, reinforcement learning, dynamics modeling, embodied intelligence'],
  ['Academic note', 'Top-ranked undergraduate with national scholarship experience'],
  ['CV', 'PDF resume attached for full details']
];

const stack = [
  ['Robotics', 'ROS2, real robot deployment, multi-motor control, real-time debugging'],
  ['RL / Simulation', 'Isaac Lab, Isaac Sim, PPO, RSL-RL, PyTorch, domain randomization'],
  ['Control / Modeling', 'MPPI, nonlinear dynamics, Brush Model, MATLAB, Simulink, Simscape Multibody'],
  ['Embedded', 'STM32H7, RK3588, C/C++, Linux robot systems'],
  ['Development', 'Python, C++, Git, Docker, Distrobox, Arch Linux, Ubuntu']
];

const commandLines = [
  'ros2 launch robot bringup.launch.py',
  'python train.py task=quadruped_locomotion',
  'mppi --model brush_tire --mode drift',
  'export policy.onnx -> real_robot'
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Hao Yunlai's CV-style research homepage for robotics control, reinforcement learning, Sim2Real, and embodied AI."
    />
    <title>Hao Yunlai | Robotics Control & Embodied AI</title>
  </head>
  <body>
    <main class="page-shell">
      <header class="masthead" aria-labelledby="page-title">
        <section class="intro">
          <p class="label">Personal Research Homepage</p>
          <h1 id="page-title">Hao Yunlai</h1>
          <p class="subtitle">
            Applied Physics undergraduate at SWJTU. I work on robotics control,
            reinforcement learning, Sim2Real, dynamics modeling, and embodied intelligence.
          </p>
          <p class="subtitle zh">
            从真实机器人控制问题出发，关注四足运动控制、Sim2Real、MPPI、World Model 与 VLA。
          </p>
          <div class="contact-row" aria-label="Contact and profile links">
            <a href="mailto:hyl00250083@outlook.com">Email</a>
            <a href="https://github.com/h4cii">GitHub</a>
            <a href="/resume/hao-yunlai-cv.pdf">CV PDF</a>
          </div>
        </section>

        <aside class="terminal-card" aria-label="Robotics workflow notes">
          <div class="terminal-topbar">
            <span></span>
            <span></span>
            <span></span>
            <strong>robot-lab</strong>
          </div>
          <div class="terminal-body">
            <p><b>hao@robot-lab</b>:~$ whoami</p>
            <p>robotics_control + rl + sim2real</p>
            {commandLines.map((line) => <p><b>$</b> {line}</p>)}
          </div>
        </aside>
      </header>

      <nav class="quick-links" aria-label="Page sections">
        <a href="#profile">Profile</a>
        <a href="#projects">Projects</a>
        <a href="#demos">Demos</a>
        <a href="#artifacts">Artifacts</a>
        <a href="#cv">CV</a>
      </nav>

      <div class="content-grid">
        <article class="main-column">
          <section class="section" id="profile" aria-labelledby="profile-title">
            <p class="label">Research Profile</p>
            <h2 id="profile-title">Control-oriented robotics, with a real-hardware bias</h2>
            <div class="essay">
              <p>
                My work starts from deployable robot control: building dynamics-aware
                policies in simulation, testing them under model mismatch, and moving
                useful behavior onto physical robots.
              </p>
              <p>
                I am interested in the meeting point of model-based control,
                reinforcement learning, world models, and vision-language-action systems.
                The practical question behind the work is simple: how can a policy become
                reliable enough to matter on hardware?
              </p>
              <p>
                我希望把控制理论、强化学习和具身智能连接到真实机器人系统中，让算法不仅在仿真里表现好，
                也能在硬件约束、噪声、延迟和模型误差下稳定工作。
              </p>
            </div>
            <div class="interest-list" aria-label="Research interests">
              {interests.map((item) => <span>{item}</span>)}
            </div>
          </section>

          <section class="section" id="projects" aria-labelledby="projects-title">
            <p class="label">Selected Projects</p>
            <h2 id="projects-title">Project experience</h2>

            <div class="project-list">
              {
                projects.map((project) => (
                  <article class="project-entry">
                    <div class="project-meta">
                      <span>{project.data.status}</span>
                      <div class="tag-list" aria-label={`${project.data.title} focus areas`}>
                        {project.data.focus.map((item) => <em>{item}</em>)}
                      </div>
                    </div>

                    <div class="project-body">
                      <h3>{project.data.title}</h3>
                      <p>{project.data.subtitle}</p>
                      <ul>
                        {project.data.methods.map((method) => <li>{method}</li>)}
                      </ul>
                      {project.data.mediaStatus && <p class="media-status">{project.data.mediaStatus}</p>}
                    </div>
                  </article>
                ))
              }
            </div>
          </section>

          <section class="section" id="demos" aria-labelledby="demos-title">
            <p class="label">Debug Videos and Images</p>
            <h2 id="demos-title">Robot evidence, added only when public-safe</h2>
            <p class="section-note">
              RoboCON and quadruped RL have video/image materials. The homepage keeps compact
              preview slots here; full raw debugging videos should stay external or private until sanitized.
            </p>

            <div class="demo-list">
              {
                projects.map((project) => (
                  <article class="demo-entry">
                    <div class="demo-media">
                      {project.data.previewSrc ? (
                        <video
                          controls
                          muted
                          playsinline
                          preload="metadata"
                          aria-label={`${project.data.title} preview video`}
                        >
                          <source src={project.data.previewSrc} />
                          <a href={project.data.previewSrc}>Open preview video</a>
                        </video>
                      ) : (
                        <div class="demo-placeholder">
                          <span>{project.data.previewLabel}</span>
                          <small>{project.data.mediaStatus || 'Preview asset pending.'}</small>
                        </div>
                      )}
                    </div>
                    <div class="demo-copy">
                      <h3>{project.data.title}</h3>
                      <p>{project.data.privacyNote}</p>
                      {project.data.fullDemoUrl ? (
                        <a class="text-link" href={project.data.fullDemoUrl}>Watch full demo</a>
                      ) : (
                        <span class="muted-link">Demo link pending</span>
                      )}
                    </div>
                  </article>
                ))
              }
            </div>
          </section>
        </article>

        <aside class="side-column" aria-label="CV and research artifacts">
          <section class="aside-block" id="cv">
            <p class="label">CV Snapshot</p>
            <dl class="profile-list">
              {
                profile.map(([label, value]) => (
                  <>
                    <dt>{label}</dt>
                    <dd>{value}</dd>
                  </>
                ))
              }
            </dl>
            <a class="cv-button" href="/resume/hao-yunlai-cv.pdf">Download CV PDF</a>
          </section>

          <section class="aside-block" id="artifacts">
            <p class="label">Research Artifacts</p>
            <div class="artifact-list">
              <div>
                <strong>Preprint</strong>
                <span>arXiv link will be added after public release.</span>
              </div>
              <div>
                <strong>Paper figure</strong>
                <span>Paper screenshot/figure slot reserved for future public material.</span>
              </div>
              <div>
                <strong>Robot demos</strong>
                <span>Short RoboCON and quadruped RL previews can be embedded here.</span>
              </div>
            </div>
          </section>

          <section class="aside-block">
            <p class="label">Technical Stack</p>
            <div class="stack-list">
              {
                stack.map(([label, value]) => (
                  <div class="stack-item">
                    <strong>{label}</strong>
                    <span>{value}</span>
                  </div>
                ))
              }
            </div>
          </section>
        </aside>
      </div>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --bg: #f3f0e8;
    --paper: #fffdf7;
    --ink: #182235;
    --muted: #667085;
    --line: #d9d2c2;
    --soft: #f8f4ea;
    --terminal: #121821;
    --terminal-line: #273241;
    --blue: #285ea8;
    --green: #12715f;
    --cyan: #0f8095;
    --amber: #a86a13;
    --red: #9f3f51;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background:
      linear-gradient(90deg, rgba(18, 24, 33, 0.035) 1px, transparent 1px),
      linear-gradient(rgba(18, 24, 33, 0.03) 1px, transparent 1px),
      var(--bg);
    background-size: 28px 28px;
    color: var(--ink);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    line-height: 1.62;
  }

  a {
    color: var(--blue);
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
  }

  .page-shell {
    width: calc(100% - 36px);
    max-width: 1120px;
    margin: 0 auto;
    padding: 36px 0 72px;
  }

  .masthead {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 360px);
    gap: 36px;
    align-items: end;
    border-bottom: 2px solid var(--ink);
    padding-bottom: 28px;
  }

  .label {
    margin: 0 0 10px;
    color: var(--cyan);
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p,
  dd,
  a,
  span,
  small,
  em {
    max-width: 100%;
    overflow-wrap: anywhere;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    margin-bottom: 14px;
    font-size: clamp(2.7rem, 6vw, 4.9rem);
    line-height: 0.98;
    letter-spacing: 0;
  }

  h2 {
    margin-bottom: 18px;
    font-size: clamp(1.45rem, 2.4vw, 2rem);
    line-height: 1.18;
    letter-spacing: 0;
  }

  h3 {
    margin-bottom: 8px;
    font-size: 1.08rem;
    line-height: 1.25;
    letter-spacing: 0;
  }

  .subtitle {
    max-width: 760px;
    margin-bottom: 8px;
    color: #29364d;
    font-size: 1.08rem;
  }

  .subtitle.zh {
    color: #59677d;
    font-size: 1rem;
  }

  .contact-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 22px;
  }

  .contact-row a,
  .cv-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 36px;
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 0 12px;
    background: rgba(255, 253, 247, 0.82);
    color: var(--ink);
    font-weight: 750;
    text-decoration: none;
  }

  .contact-row a:first-child,
  .cv-button {
    border-color: var(--green);
    color: var(--green);
  }

  .terminal-card {
    overflow: hidden;
    border: 1px solid var(--terminal-line);
    border-radius: 8px;
    background: var(--terminal);
    box-shadow: 8px 8px 0 rgba(40, 94, 168, 0.13);
  }

  .terminal-topbar {
    display: flex;
    align-items: center;
    gap: 8px;
    border-bottom: 1px solid var(--terminal-line);
    padding: 10px 14px;
    color: #9fb1c7;
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
    font-size: 0.82rem;
  }

  .terminal-topbar span {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: #e36b6b;
  }

  .terminal-topbar span:nth-child(2) {
    background: #d2a63b;
  }

  .terminal-topbar span:nth-child(3) {
    background: #2aa879;
  }

  .terminal-topbar strong {
    margin-left: auto;
    font-weight: 700;
  }

  .terminal-body {
    padding: 14px;
    color: #d8e5f2;
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
    font-size: 0.84rem;
  }

  .terminal-body p {
    margin-bottom: 8px;
  }

  .terminal-body b {
    color: #4fd1aa;
  }

  .quick-links {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    border-bottom: 1px solid var(--line);
    padding: 14px 0;
    font-size: 0.94rem;
  }

  .quick-links a {
    color: #344054;
    font-weight: 750;
    text-decoration: none;
  }

  .content-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 42px;
    align-items: start;
  }

  .section {
    padding: 42px 0;
    border-bottom: 1px solid var(--line);
  }

  .essay {
    display: grid;
    gap: 12px;
    color: #344054;
  }

  .essay p {
    margin-bottom: 0;
  }

  .interest-list,
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 22px;
  }

  .interest-list span,
  .tag-list em {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 5px 10px;
    background: var(--paper);
    color: #344054;
    font-size: 0.88rem;
    font-style: normal;
    font-weight: 650;
  }

  .project-list,
  .demo-list,
  .stack-list,
  .artifact-list {
    display: grid;
    gap: 18px;
  }

  .project-entry {
    display: grid;
    grid-template-columns: 215px minmax(0, 1fr);
    gap: 24px;
    padding: 22px 0;
    border-top: 1px solid var(--line);
  }

  .project-entry:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .project-meta > span {
    display: block;
    color: var(--red);
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
    font-size: 0.82rem;
    font-weight: 750;
  }

  .project-body p,
  .section-note,
  .demo-copy p,
  .media-status {
    color: #48566d;
  }

  .media-status {
    margin: 12px 0 0;
    font-size: 0.92rem;
  }

  ul {
    margin: 12px 0 0;
    padding-left: 18px;
    color: #344054;
  }

  li + li {
    margin-top: 5px;
  }

  .demo-entry {
    display: grid;
    grid-template-columns: 248px minmax(0, 1fr);
    gap: 20px;
    align-items: stretch;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 253, 247, 0.86);
    padding: 14px;
  }

  .demo-media {
    min-height: 146px;
    border: 1px solid #c8d5d2;
    border-radius: 6px;
    overflow: hidden;
    background:
      linear-gradient(135deg, rgba(18, 113, 95, 0.18), transparent 42%),
      linear-gradient(315deg, rgba(40, 94, 168, 0.18), transparent 46%),
      #182235;
  }

  video {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 146px;
    object-fit: cover;
  }

  .demo-placeholder {
    display: grid;
    align-content: center;
    min-height: 146px;
    padding: 16px;
    color: #e8f3ef;
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
  }

  .demo-placeholder span {
    font-weight: 800;
  }

  .demo-placeholder small {
    color: #aebfc7;
  }

  .demo-copy {
    display: grid;
    align-content: center;
  }

  .text-link,
  .muted-link {
    font-size: 0.94rem;
    font-weight: 700;
  }

  .muted-link {
    color: var(--muted);
  }

  .side-column {
    position: sticky;
    top: 24px;
    padding-top: 42px;
  }

  .aside-block {
    border-top: 2px solid var(--ink);
    padding: 18px 0 28px;
  }

  .profile-list {
    display: grid;
    gap: 10px;
    margin: 0 0 16px;
  }

  .profile-list dt {
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .profile-list dd {
    margin: 0 0 10px;
    color: #29364d;
  }

  .artifact-list div,
  .stack-item {
    display: grid;
    gap: 3px;
    border-left: 3px solid var(--green);
    padding-left: 12px;
  }

  .artifact-list div:nth-child(2) {
    border-left-color: var(--blue);
  }

  .artifact-list div:nth-child(3) {
    border-left-color: var(--amber);
  }

  .artifact-list strong,
  .stack-item strong {
    color: #243047;
  }

  .artifact-list span,
  .stack-item span {
    color: var(--muted);
    font-size: 0.94rem;
  }

  @media (max-width: 930px) {
    .page-shell {
      width: calc(100% - 24px);
      padding-top: 28px;
    }

    .masthead,
    .content-grid,
    .project-entry,
    .demo-entry {
      grid-template-columns: 1fr;
    }

    .terminal-card {
      max-width: 520px;
    }

    .side-column {
      position: static;
      padding-top: 0;
    }
  }

  @media (max-width: 560px) {
    h1 {
      font-size: 2.8rem;
    }

    .quick-links,
    .contact-row {
      gap: 10px;
    }

    .contact-row a {
      flex: 1 1 auto;
    }

    .section {
      padding: 34px 0;
    }

    .demo-entry {
      padding: 12px;
    }
  }
</style>
