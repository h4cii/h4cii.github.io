---
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);

const interests = [
  'Quadruped locomotion',
  'Reinforcement learning',
  'Sim2Real',
  'Robot dynamics',
  'MPPI',
  'Friction-aware control',
  'Embedded robot systems',
  'Legged robot hardware'
];

const profile = [
  ['Education', 'Applied Physics B.Sc. candidate, Southwest Jiaotong University, 2023-2027'],
  ['Academic record', 'GPA 3.92/4.00, average score 91.91/100, ranked 2/196 in major'],
  ['Research', 'RL quadruped locomotion, Sim2Real deployment, friction-aware MPPI, robot dynamics'],
  ['Honors', 'National Scholarship 2024/2025; multiple national robotics and modeling awards']
];

const stack = [
  ['Robotics', 'ROS2, MuJoCo, real robot deployment, action mapping, state observation, closed-loop debugging'],
  ['RL / Simulation', 'Isaac Lab, Isaac Sim 5.1, PPO, RSL-RL, PyTorch, domain randomization'],
  ['Control / Modeling', 'MPPI, nonlinear MPC, Brush Tire Model, Newton-Euler dynamics, MATLAB, Simscape'],
  ['Embedded', 'STM32H7, RK3588, FreeRTOS, CAN/RS485, motor debugging for Unitree, Damiao, Lingzu'],
  ['Development', 'Python, C/C++, MATLAB, Linux, Git, Docker, Arch Linux, Ubuntu']
];

const commandLines = [
  'ros2 launch robot bringup.launch.py',
  'python train.py task=quadruped_locomotion sim=isaac_lab',
  'mppi --model brush_tire --terminal-value',
  'sim2sim mujoco -> sim2real physical_robot'
];

type DemoEntry =
  | {
      kind: 'video';
      projectTitle: string;
      title: string;
      src: string;
      caption: string;
      muted: boolean;
    }
  | {
      kind: 'placeholder';
      projectTitle: string;
      title: string;
      previewLabel: string;
      caption: string;
      mediaStatus: string;
    };

const demoEntries: DemoEntry[] = projects.flatMap<DemoEntry>((project) => {
  const demos = project.data.demos ?? [];

  if (demos.length > 0) {
    return demos.map((demo) => ({
      kind: 'video' as const,
      projectTitle: project.data.title,
      title: demo.title,
      src: demo.src,
      caption: demo.caption,
      muted: demo.muted ?? false
    }));
  }

  return [
    {
      kind: 'placeholder' as const,
      projectTitle: project.data.title,
      title: project.data.title,
      previewLabel: project.data.previewLabel,
      caption: project.data.privacyNote,
      mediaStatus: project.data.mediaStatus || 'Preview asset pending.'
    }
  ];
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Hao Yunlai's research homepage for quadruped robot control, reinforcement learning, Sim2Real, friction-aware MPPI, and embedded robot systems."
    />
    <title>Hao Yunlai | Robotics Control & Embodied AI</title>
  </head>
  <body>
    <main class="page-shell">
      <header class="masthead" aria-labelledby="page-title">
        <section class="intro">
          <p class="label">Personal Research Homepage</p>
          <h1 id="page-title">Hao Yunlai</h1>
          <p class="subtitle">
            Applied Physics undergraduate at SWJTU, ranked 2/196 with a 3.92/4.00 GPA.
            I work on quadruped robot control, reinforcement learning, Sim2Real,
            friction-aware trajectory tracking, and embedded robot systems.
          </p>
          <p class="subtitle zh">
            我关注从仿真训练到实机闭环的机器人控制问题，主要方向包括四足机器人强化学习运动控制、
            Sim2Real 部署、复杂地形稳定运动、摩擦感知 MPPI 与嵌入式实时控制系统。
          </p>
          <div class="contact-row" aria-label="Contact and profile links">
            <a href="mailto:haoyl42@163.com">Email</a>
            <a href="https://github.com/h4cii">GitHub</a>
            <a href="/resume/hao-yunlai-cv.pdf">CV PDF</a>
          </div>
        </section>

        <aside class="terminal-card" aria-label="Robotics workflow notes">
          <div class="terminal-topbar">
            <span></span>
            <span></span>
            <span></span>
            <strong>code &amp; math</strong>
          </div>
          <div class="terminal-body">
            <p><b>hao@code-math</b>:~$ whoami</p>
            <p>robotics_control + rl + sim2real</p>
            {commandLines.map((line) => <p><b>$</b> {line}</p>)}
          </div>
        </aside>
      </header>

      <nav class="quick-links" aria-label="Page sections">
        <a href="#profile">Profile</a>
        <a href="#demos">Demos</a>
        <a href="#projects">Projects</a>
        <a href="#artifacts">Artifacts</a>
        <a href="#cv">CV</a>
      </nav>

      <div class="content-grid">
        <article class="main-column">
          <section class="section" id="profile" aria-labelledby="profile-title">
            <p class="label">Research Profile</p>
            <h2 id="profile-title">Control-oriented robotics, with a real-hardware bias</h2>
            <div class="essay">
              <p>
                My work starts from deployable robot control. I build simulation training
                pipelines, design observations and domain randomization, verify policies
                in MuJoCo, and move useful behavior onto physical quadruped hardware.
              </p>
              <p>
                My current projects connect reinforcement learning, dynamics modeling,
                sampling-based optimal control, and embedded implementation. The practical
                question behind the work is simple: how can a controller stay reliable
                under terrain changes, actuator limits, delay, noise, and model mismatch?
              </p>
              <p>
                我希望把控制理论、强化学习和机器人系统工程连接到真实硬件中，让算法不仅能在仿真里跑通，
                也能在物理样机的通信延迟、电机约束、轮地/足地接触误差和复杂地形中稳定工作。
              </p>
            </div>
            <div class="interest-list" aria-label="Research interests">
              {interests.map((item) => <span>{item}</span>)}
            </div>
          </section>

          <section class="section" id="demos" aria-labelledby="demos-title">
            <p class="label">Debug Videos and Images</p>
            <h2 id="demos-title">Robot hardware and terrain demos</h2>
            <p class="section-note">
              Short embedded clips from terrain traversal and flat-ground Sim2Real deployment.
              The flat-ground clip is intentionally audio-free for public display.
            </p>

            <div class="demo-list">
              {
                demoEntries.map((demo) => (
                  <article class="demo-entry">
                    <div class="demo-media">
                      {demo.kind === 'video' ? (
                        <video
                          controls
                          muted={demo.muted}
                          playsinline
                          preload="metadata"
                          aria-label={`${demo.title} preview video`}
                        >
                          <source src={demo.src} type="video/mp4" />
                          <a href={demo.src}>Open preview video</a>
                        </video>
                      ) : (
                        <div class="demo-placeholder">
                          <span>{demo.previewLabel}</span>
                          <small>{demo.mediaStatus}</small>
                        </div>
                      )}
                    </div>
                    <div class="demo-copy">
                      <span class="demo-project">{demo.projectTitle}</span>
                      <h3>{demo.title}</h3>
                      <p>{demo.caption}</p>
                      {demo.kind === 'video' ? (
                        <a class="text-link" href={demo.src}>Open video file</a>
                      ) : (
                        <span class="muted-link">Demo link pending</span>
                      )}
                    </div>
                  </article>
                ))
              }
            </div>
          </section>

          <section class="section" id="projects" aria-labelledby="projects-title">
            <p class="label">Selected Projects</p>
            <h2 id="projects-title">Project experience</h2>

            <div class="project-list">
              {
                projects.map((project) => (
                  <article class="project-entry">
                    <div class="project-meta">
                      <span>{project.data.status}</span>
                      <div class="tag-list" aria-label={`${project.data.title} focus areas`}>
                        {project.data.focus.map((item) => <em>{item}</em>)}
                      </div>
                    </div>

                    <div class="project-body">
                      <h3>{project.data.title}</h3>
                      <p>{project.data.subtitle}</p>
                      <ul>
                        {project.data.methods.map((method) => <li>{method}</li>)}
                      </ul>
                      {project.data.mediaStatus && <p class="media-status">{project.data.mediaStatus}</p>}
                    </div>
                  </article>
                ))
              }
            </div>
          </section>
        </article>

        <aside class="side-column" aria-label="CV and research artifacts">
          <section class="aside-block" id="cv">
            <p class="label">CV Snapshot</p>
            <dl class="profile-list">
              {
                profile.map(([label, value]) => (
                  <>
                    <dt>{label}</dt>
                    <dd>{value}</dd>
                  </>
                ))
              }
            </dl>
            <a class="cv-button" href="/resume/hao-yunlai-cv.pdf">Download CV PDF</a>
          </section>

          <section class="aside-block" id="artifacts">
            <p class="label">Research Artifacts</p>
            <div class="artifact-list">
              <div>
                <strong>Preprint</strong>
                <span>Friction-aware trajectory tracking with infinite-horizon-cost-augmented MPPI is under revision.</span>
              </div>
              <div>
                <strong>Academic record</strong>
                <span>Ranked 2/196 in Applied Physics, with National Scholarship in 2024 and 2025.</span>
              </div>
              <div>
                <strong>Robot demos</strong>
                <span>Quadruped RL terrain traversal and flat-ground Sim2Real clips are embedded above.</span>
              </div>
            </div>
          </section>

          <section class="aside-block">
            <p class="label">Technical Stack</p>
            <div class="stack-list">
              {
                stack.map(([label, value]) => (
                  <div class="stack-item">
                    <strong>{label}</strong>
                    <span>{value}</span>
                  </div>
                ))
              }
            </div>
          </section>
        </aside>
      </div>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --bg: #f3f0e8;
    --paper: #fffdf7;
    --ink: #182235;
    --muted: #667085;
    --line: #d9d2c2;
    --soft: #f8f4ea;
    --terminal: #121821;
    --terminal-line: #273241;
    --blue: #285ea8;
    --green: #12715f;
    --cyan: #0f8095;
    --amber: #a86a13;
    --red: #9f3f51;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background:
      linear-gradient(90deg, rgba(18, 24, 33, 0.035) 1px, transparent 1px),
      linear-gradient(rgba(18, 24, 33, 0.03) 1px, transparent 1px),
      var(--bg);
    background-size: 28px 28px;
    color: var(--ink);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    line-height: 1.62;
  }

  a {
    color: var(--blue);
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
  }

  .page-shell {
    width: calc(100% - 36px);
    max-width: 1120px;
    margin: 0 auto;
    padding: 36px 0 72px;
  }

  .masthead {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 360px);
    gap: 36px;
    align-items: end;
    border-bottom: 2px solid var(--ink);
    padding-bottom: 28px;
  }

  .label {
    margin: 0 0 10px;
    color: var(--cyan);
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p,
  dd,
  a,
  span,
  small,
  em {
    max-width: 100%;
    overflow-wrap: anywhere;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    margin-bottom: 14px;
    font-size: clamp(2.7rem, 6vw, 4.9rem);
    line-height: 0.98;
    letter-spacing: 0;
  }

  h2 {
    margin-bottom: 18px;
    font-size: clamp(1.45rem, 2.4vw, 2rem);
    line-height: 1.18;
    letter-spacing: 0;
  }

  h3 {
    margin-bottom: 8px;
    font-size: 1.08rem;
    line-height: 1.25;
    letter-spacing: 0;
  }

  .subtitle {
    max-width: 760px;
    margin-bottom: 8px;
    color: #29364d;
    font-size: 1.08rem;
  }

  .subtitle.zh {
    color: #59677d;
    font-size: 1rem;
  }

  .contact-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 22px;
  }

  .contact-row a,
  .cv-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 36px;
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 0 12px;
    background: rgba(255, 253, 247, 0.82);
    color: var(--ink);
    font-weight: 750;
    text-decoration: none;
  }

  .contact-row a:first-child,
  .cv-button {
    border-color: var(--green);
    color: var(--green);
  }

  .terminal-card {
    overflow: hidden;
    border: 1px solid var(--terminal-line);
    border-radius: 8px;
    background: var(--terminal);
    box-shadow: 8px 8px 0 rgba(40, 94, 168, 0.13);
  }

  .terminal-topbar {
    display: flex;
    align-items: center;
    gap: 8px;
    border-bottom: 1px solid var(--terminal-line);
    padding: 10px 14px;
    color: #9fb1c7;
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
    font-size: 0.82rem;
  }

  .terminal-topbar span {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: #e36b6b;
  }

  .terminal-topbar span:nth-child(2) {
    background: #d2a63b;
  }

  .terminal-topbar span:nth-child(3) {
    background: #2aa879;
  }

  .terminal-topbar strong {
    margin-left: auto;
    font-weight: 700;
  }

  .terminal-body {
    padding: 14px;
    color: #d8e5f2;
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
    font-size: 0.84rem;
  }

  .terminal-body p {
    margin-bottom: 8px;
  }

  .terminal-body b {
    color: #4fd1aa;
  }

  .quick-links {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    border-bottom: 1px solid var(--line);
    padding: 14px 0;
    font-size: 0.94rem;
  }

  .quick-links a {
    color: #344054;
    font-weight: 750;
    text-decoration: none;
  }

  .content-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 42px;
    align-items: start;
  }

  .section {
    padding: 42px 0;
    border-bottom: 1px solid var(--line);
  }

  .essay {
    display: grid;
    gap: 12px;
    color: #344054;
  }

  .essay p {
    margin-bottom: 0;
  }

  .interest-list,
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 22px;
  }

  .interest-list span,
  .tag-list em {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 5px 10px;
    background: var(--paper);
    color: #344054;
    font-size: 0.88rem;
    font-style: normal;
    font-weight: 650;
  }

  .project-list,
  .demo-list,
  .stack-list,
  .artifact-list {
    display: grid;
    gap: 18px;
  }

  .demo-list {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 22px;
  }

  .project-entry {
    display: grid;
    grid-template-columns: 215px minmax(0, 1fr);
    gap: 24px;
    padding: 22px 0;
    border-top: 1px solid var(--line);
  }

  .project-entry:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .project-meta > span {
    display: block;
    color: var(--red);
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
    font-size: 0.82rem;
    font-weight: 750;
  }

  .project-body p,
  .section-note,
  .demo-copy p,
  .media-status {
    color: #48566d;
  }

  .media-status {
    margin: 12px 0 0;
    font-size: 0.92rem;
  }

  ul {
    margin: 12px 0 0;
    padding-left: 18px;
    color: #344054;
  }

  li + li {
    margin-top: 5px;
  }

  .demo-entry {
    display: grid;
    grid-template-rows: auto 1fr;
    align-items: stretch;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 253, 247, 0.86);
    overflow: hidden;
    padding: 0;
  }

  .demo-media {
    aspect-ratio: 16 / 9;
    min-height: 0;
    border-bottom: 1px solid var(--line);
    overflow: hidden;
    background:
      linear-gradient(135deg, rgba(18, 113, 95, 0.18), transparent 42%),
      linear-gradient(315deg, rgba(40, 94, 168, 0.18), transparent 46%),
      #182235;
  }

  video {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 0;
    object-fit: contain;
    background: #0e1622;
  }

  .demo-placeholder {
    display: grid;
    height: 100%;
    min-height: 0;
    place-content: center;
    padding: 18px;
    color: #e8f3ef;
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
  }

  .demo-placeholder span {
    font-weight: 800;
  }

  .demo-placeholder small {
    color: #aebfc7;
  }

  .demo-copy {
    display: grid;
    align-content: start;
    padding: 16px;
  }

  .demo-copy p {
    margin-bottom: 14px;
  }

  .demo-project {
    display: inline-flex;
    width: fit-content;
    margin-bottom: 12px;
    border-radius: 999px;
    padding: 3px 9px;
    background: rgba(40, 94, 168, 0.12);
    color: var(--blue);
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
    font-size: 0.76rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .text-link,
  .muted-link {
    font-size: 0.94rem;
    font-weight: 700;
  }

  .muted-link {
    color: var(--muted);
  }

  .side-column {
    position: sticky;
    top: 24px;
    padding-top: 42px;
  }

  .aside-block {
    border-top: 2px solid var(--ink);
    padding: 18px 0 28px;
  }

  .profile-list {
    display: grid;
    gap: 10px;
    margin: 0 0 16px;
  }

  .profile-list dt {
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .profile-list dd {
    margin: 0 0 10px;
    color: #29364d;
  }

  .artifact-list div,
  .stack-item {
    display: grid;
    gap: 3px;
    border-left: 3px solid var(--green);
    padding-left: 12px;
  }

  .artifact-list div:nth-child(2) {
    border-left-color: var(--blue);
  }

  .artifact-list div:nth-child(3) {
    border-left-color: var(--amber);
  }

  .artifact-list strong,
  .stack-item strong {
    color: #243047;
  }

  .artifact-list span,
  .stack-item span {
    color: var(--muted);
    font-size: 0.94rem;
  }

  @media (max-width: 930px) {
    .page-shell {
      width: calc(100% - 24px);
      padding-top: 28px;
    }

    .masthead,
    .content-grid,
    .project-entry {
      grid-template-columns: 1fr;
    }

    .demo-list {
      grid-template-columns: 1fr;
    }

    .terminal-card {
      max-width: 520px;
    }

    .side-column {
      position: static;
      padding-top: 0;
    }
  }

  @media (max-width: 560px) {
    h1 {
      font-size: 2.8rem;
    }

    .quick-links,
    .contact-row {
      gap: 10px;
    }

    .contact-row a {
      flex: 1 1 auto;
    }

    .section {
      padding: 34px 0;
    }

    .demo-entry {
      padding: 0;
    }

    .demo-copy {
      padding: 14px;
    }
  }
</style>
