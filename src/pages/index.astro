---
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);

const interests = [
  'Quadruped locomotion',
  'Reinforcement learning',
  'Sim2Real deployment',
  'Robot dynamics',
  'MPPI',
  'World models and VLA'
];

const profile = [
  {
    label: 'Current position',
    value: 'Applied Physics undergraduate at Southwest Jiaotong University'
  },
  {
    label: 'Research direction',
    value: 'Robotics control, reinforcement learning, dynamics modeling, and embodied intelligence'
  },
  {
    label: 'Academic note',
    value: 'Top-ranked undergraduate with national scholarship experience'
  }
];

const stack = [
  ['Robotics', 'ROS2, real robot deployment, multi-motor control, embedded debugging'],
  ['RL and simulation', 'Isaac Lab, Isaac Sim, PPO, RSL-RL, PyTorch, domain randomization'],
  ['Control and modeling', 'MPPI, nonlinear dynamics, Brush Model, MATLAB, Simulink, Simscape Multibody'],
  ['Embedded systems', 'STM32H7, RK3588, C/C++, Linux robot systems'],
  ['Development', 'Python, C++, Git, Docker, Distrobox, Arch Linux, Ubuntu']
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Hao Yunlai's CV-style research homepage for robotics control, reinforcement learning, Sim2Real, and embodied AI."
    />
    <title>Hao Yunlai | Robotics Control & Embodied AI</title>
  </head>
  <body>
    <main>
      <section class="hero" aria-labelledby="page-title">
        <div class="hero-copy">
          <p class="eyebrow">Robotics Control / Reinforcement Learning / Sim2Real</p>
          <h1 id="page-title">Hao Yunlai</h1>
          <p class="lead">
            Applied Physics undergraduate at SWJTU working on robotics control,
            reinforcement learning, dynamics modeling, and embodied intelligence.
          </p>
          <p class="lead-zh">
            从真实机器人控制问题出发，关注四足运动控制、Sim2Real、MPPI、World Model 与 VLA。
          </p>
          <div class="hero-actions" aria-label="Contact links">
            <a class="button primary" href="mailto:hyl00250083@outlook.com">Email</a>
            <a class="button" href="https://github.com/h4cii">GitHub</a>
          </div>
        </div>

        <div class="signal-panel" aria-label="Research signal summary">
          <div class="signal-row">
            <span>Policy</span>
            <div class="signal-line strong"></div>
          </div>
          <div class="signal-row">
            <span>Dynamics</span>
            <div class="signal-line medium"></div>
          </div>
          <div class="signal-row">
            <span>Deployment</span>
            <div class="signal-line long"></div>
          </div>
          <div class="signal-grid">
            {interests.map((item) => <span>{item}</span>)}
          </div>
        </div>
      </section>

      <section class="section" aria-labelledby="profile-title">
        <div class="section-heading">
          <p class="eyebrow">Research Profile</p>
          <h2 id="profile-title">Control-first embodied intelligence</h2>
        </div>
        <div class="profile-text">
          <p>
            My work starts from deployable robot control: building dynamics-aware
            policies in simulation, pressure-testing them under mismatch, and
            moving useful behavior onto physical robots.
          </p>
          <p>
            我希望把模型控制、强化学习、世界模型和具身智能连接到可落地的机器人系统中，
            让算法既能在仿真中学习，也能在真实硬件上稳定工作。
          </p>
        </div>
      </section>

      <section class="section" aria-labelledby="projects-title">
        <div class="section-heading">
          <p class="eyebrow">Selected Projects</p>
          <h2 id="projects-title">Robot systems with real deployment pressure</h2>
        </div>

        <div class="projects">
          {
            projects.map((project) => (
              <article class="project-card">
                <div class="video-shell">
                  {project.data.previewSrc ? (
                    <video
                      controls
                      muted
                      playsinline
                      preload="metadata"
                      aria-label={`${project.data.title} preview video`}
                    >
                      <source src={project.data.previewSrc} />
                      <a href={project.data.previewSrc}>Open preview video</a>
                    </video>
                  ) : (
                    <div class="video-placeholder">
                      <span>{project.data.previewLabel}</span>
                      <small>Drop a sanitized 5-15s WebM/MP4 clip into public/media/previews.</small>
                    </div>
                  )}
                </div>

                <div class="project-content">
                  <div class="project-kicker">{project.data.status}</div>
                  <h3>{project.data.title}</h3>
                  <p>{project.data.subtitle}</p>

                  <div class="tag-row" aria-label={`${project.data.title} focus areas`}>
                    {project.data.focus.map((item) => <span>{item}</span>)}
                  </div>

                  <ul>
                    {project.data.methods.map((method) => <li>{method}</li>)}
                  </ul>

                  <p class="privacy-note">{project.data.privacyNote}</p>

                  {
                    project.data.fullDemoUrl ? (
                      <a class="inline-link" href={project.data.fullDemoUrl}>
                        Watch full demo
                      </a>
                    ) : (
                      <span class="inline-link disabled">Full demo link pending</span>
                    )
                  }
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section two-column" aria-labelledby="cv-title">
        <div>
          <div class="section-heading">
            <p class="eyebrow">CV Snapshot</p>
            <h2 id="cv-title">Compact public profile</h2>
          </div>
          <dl class="snapshot">
            {
              profile.map((item) => (
                <>
                  <dt>{item.label}</dt>
                  <dd>{item.value}</dd>
                </>
              ))
            }
          </dl>
        </div>

        <div>
          <div class="section-heading compact">
            <p class="eyebrow">Technical Stack</p>
            <h2>Tools I use</h2>
          </div>
          <div class="stack-list">
            {stack.map(([label, value]) => (
              <div class="stack-item">
                <strong>{label}</strong>
                <span>{value}</span>
              </div>
            ))}
          </div>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --bg: #f7f8fb;
    --surface: #ffffff;
    --ink: #172033;
    --muted: #5f6c80;
    --line: #dfe5ee;
    --blue: #225cc8;
    --green: #167a63;
    --amber: #b35f00;
    --red: #b83b5e;
    --shadow: 0 18px 48px rgba(24, 35, 54, 0.1);
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--ink);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    line-height: 1.6;
  }

  body::before {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(34, 92, 200, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(22, 122, 99, 0.05) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: linear-gradient(to bottom, #000 0%, transparent 72%);
  }

  main {
    position: relative;
    width: calc(100% - 32px);
    max-width: 1120px;
    margin: 0 auto;
    padding: 56px 0 72px;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
    gap: 40px;
    align-items: center;
    min-height: 78vh;
    padding-bottom: 32px;
  }

  .hero-copy {
    max-width: 720px;
  }

  .eyebrow {
    margin: 0 0 12px;
    color: var(--blue);
    font-size: 0.78rem;
    font-weight: 750;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p,
  a,
  span,
  dd {
    margin-top: 0;
    max-width: 100%;
    overflow-wrap: anywhere;
  }

  h1 {
    margin-bottom: 18px;
    font-size: clamp(3.1rem, 7vw, 6.4rem);
    line-height: 0.94;
    letter-spacing: 0;
  }

  h2 {
    margin-bottom: 16px;
    font-size: clamp(1.9rem, 3.5vw, 3.2rem);
    line-height: 1.05;
    letter-spacing: 0;
  }

  h3 {
    margin-bottom: 10px;
    font-size: 1.35rem;
    line-height: 1.2;
    letter-spacing: 0;
  }

  .lead {
    max-width: 660px;
    margin-bottom: 12px;
    color: #2d3a51;
    font-size: clamp(1.08rem, 2vw, 1.28rem);
  }

  .lead-zh {
    max-width: 660px;
    color: var(--muted);
    font-size: 1rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 26px;
  }

  .button,
  .inline-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0 16px;
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--ink);
    font-weight: 700;
    text-decoration: none;
    background: var(--surface);
  }

  .button.primary {
    border-color: var(--blue);
    background: var(--blue);
    color: #ffffff;
  }

  .signal-panel {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.82);
    box-shadow: var(--shadow);
    padding: 28px;
  }

  .signal-row {
    display: grid;
    grid-template-columns: 96px 1fr;
    gap: 16px;
    align-items: center;
    margin-bottom: 16px;
    color: var(--muted);
    font-weight: 700;
  }

  .signal-line {
    height: 18px;
    border-radius: 999px;
    background: var(--line);
    overflow: hidden;
  }

  .signal-line::before {
    content: "";
    display: block;
    height: 100%;
    border-radius: inherit;
  }

  .signal-line.strong::before {
    width: 88%;
    background: var(--blue);
  }

  .signal-line.medium::before {
    width: 76%;
    background: var(--green);
  }

  .signal-line.long::before {
    width: 82%;
    background: var(--amber);
  }

  .signal-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    margin-top: 28px;
  }

  .signal-grid span,
  .tag-row span {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 8px 10px;
    background: #fbfcff;
    color: #2b374a;
    font-size: 0.9rem;
    font-weight: 650;
  }

  .section {
    padding: 56px 0;
    border-top: 1px solid var(--line);
  }

  .section-heading {
    max-width: 760px;
  }

  .section-heading.compact h2 {
    font-size: 2rem;
  }

  .profile-text {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
    color: #2d3a51;
    font-size: 1.04rem;
  }

  .projects {
    display: grid;
    gap: 20px;
  }

  .project-card {
    display: grid;
    grid-template-columns: minmax(280px, 0.86fr) minmax(0, 1.14fr);
    gap: 0;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
    box-shadow: 0 12px 34px rgba(24, 35, 54, 0.07);
  }

  .video-shell {
    min-height: 280px;
    background:
      linear-gradient(135deg, rgba(34, 92, 200, 0.16), transparent 42%),
      linear-gradient(315deg, rgba(22, 122, 99, 0.18), transparent 44%),
      #182336;
  }

  video {
    width: 100%;
    height: 100%;
    min-height: 280px;
    display: block;
    object-fit: cover;
  }

  .video-placeholder {
    display: grid;
    align-content: end;
    gap: 8px;
    min-height: 280px;
    padding: 22px;
    color: #ffffff;
  }

  .video-placeholder span {
    font-size: 1.16rem;
    font-weight: 800;
  }

  .video-placeholder small {
    max-width: 320px;
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.86rem;
  }

  .project-content {
    padding: 28px;
  }

  .project-kicker {
    margin-bottom: 8px;
    color: var(--red);
    font-size: 0.84rem;
    font-weight: 750;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 18px 0;
  }

  ul {
    padding-left: 18px;
    margin: 0 0 16px;
    color: #334159;
  }

  li + li {
    margin-top: 6px;
  }

  .privacy-note {
    margin-bottom: 14px;
    color: var(--muted);
    font-size: 0.92rem;
  }

  .inline-link {
    width: fit-content;
    min-height: 36px;
    color: var(--blue);
  }

  .inline-link.disabled {
    color: var(--muted);
  }

  .two-column {
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    gap: 48px;
  }

  .snapshot {
    display: grid;
    gap: 12px;
    margin: 0;
  }

  .snapshot dt {
    color: var(--muted);
    font-size: 0.86rem;
    font-weight: 800;
  }

  .snapshot dd {
    margin: 0 0 10px;
    color: #2d3a51;
  }

  .stack-list {
    display: grid;
    gap: 12px;
  }

  .stack-item {
    display: grid;
    gap: 4px;
    border-left: 4px solid var(--green);
    padding: 10px 0 10px 14px;
    background: rgba(255, 255, 255, 0.58);
  }

  .stack-item span {
    color: var(--muted);
  }

  @media (max-width: 900px) {
    main {
      width: calc(100% - 24px);
      max-width: 720px;
      padding-top: 32px;
    }

    .hero,
    .project-card,
    .profile-text,
    .two-column {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
    }

    .signal-panel {
      padding: 22px;
    }
  }

  @media (max-width: 560px) {
    h1 {
      font-size: 3rem;
    }

    .eyebrow {
      font-size: 0.74rem;
      line-height: 1.45;
    }

    .hero-actions,
    .tag-row {
      align-items: stretch;
      flex-direction: column;
    }

    .button,
    .inline-link {
      width: 100%;
    }

    .signal-row {
      grid-template-columns: 1fr;
      gap: 8px;
    }

    .signal-grid {
      grid-template-columns: 1fr;
    }

    .project-content,
    .video-placeholder {
      padding: 20px;
    }
  }
</style>
